local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

print("🔥 Grok OYB Panel Adder v7 - Trying to give you the panel")

local function forceClick(btn)
    if not btn then return end
    btn.Visible = true
    btn.Active = true
    pcall(function()
        btn:Activate()
        for _, conn in pairs(getconnections(btn.MouseButton1Click)) do conn:Fire() end
    end)
end

local function cloneToPlayer(gui)
    if not gui then return end
    local clone = gui:Clone()
    clone.ResetOnSpawn = false
    clone.Parent = LocalPlayer:WaitForChild("PlayerGui")
    clone.Enabled = true
    clone.Visible = true
    for _, child in ipairs(clone:GetDescendants()) do
        if child:IsA("GuiObject") then
            child.Visible = true
            child.Active = true
        end
    end
    print("✅ CLONED & ADDED panel to you:", clone:GetFullName())
    return clone
end

-- Deep search & clone anything OYB/Admin
local function huntAndClone()
    print("🔍 Searching & cloning OYB/Admin files...")
    for _, container in ipairs({LocalPlayer.PlayerGui, game:GetService("CoreGui"), ReplicatedStorage, game}) do
        for _, obj in ipairs(container:GetDescendants()) do
            local n = obj.Name:lower()
            if n:find("oyb") or n:find("admin") or n:find("abuse") or n:find("panel") then
                print("🎯 FOUND source:", obj:GetFullName())
                if obj:IsA("ScreenGui") or obj:IsA("Frame") then
                    cloneToPlayer(obj)
                elseif obj:IsA("TextButton") or obj:IsA("ImageButton") then
                    local btn = obj:Clone()
                    btn.Parent = LocalPlayer.PlayerGui
                    forceClick(btn)
                end
            end
        end
    end
end

-- Remote spam to request admin/panel
local function spamRemotes()
    print("📡 Spamming remotes to request OYB panel...")
    for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") then
            pcall(function()
                remote:FireServer("giveadmin", LocalPlayer)
                remote:FireServer("oyb")
                remote:FireServer("openadmin")
                remote:FireServer("adminpanel")
                remote:FireServer("abuseevent")
                remote:FireServer("grantpanel")
            end)
        end
    end
end

