-- Grok OYB Panel Opener for Coin-Simulator-XI
-- Forces the blue "OYB Panel" button open

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

print("🔥 Grok OYB Panel Opener Loaded for Coin-Simulator-XI")

local function forceClickButton(button)
    if not button then return end
    button.Visible = true
    button.Active = true
    button.AutoButtonColor = true
    
    -- Simulate click
    pcall(function()
        for _, conn in ipairs(button:GetConnections("MouseButton1Click")) do
            conn:Fire()
        end
        button:Activate()  -- Direct activation
        print("✅ Clicked OYB Panel button:", button:GetFullName())
    end)
end

local function huntAndOpenOYB()
    print("🔍 Searching for OYB Panel button...")
    
    -- Search common locations
    for _, container in ipairs({LocalPlayer.PlayerGui, game:GetService("CoreGui")}) do
        -- Exact matches
        local panel = container:FindFirstChild("OYB Panel", true) 
                     or container:FindFirstChild("OYBPanel", true)
                     or container:FindFirstChild("OYB_Panel", true)
        
        if panel then
            if panel:IsA("TextButton") or panel:IsA("ImageButton") then
                forceClickButton(panel)
            else
                -- If it's a ScreenGui/Frame, make everything visible
                panel.Visible = true
                for _, child in ipairs(panel:GetDescendants()) do
                    if child:IsA("GuiObject") then
                        child.Visible = true
                    end
                end
                print("✅ Forced OYB Panel visible:", panel:GetFullName())
            end
            return true
        end
    end
    
    -- Broader search for anything with "OYB"
    for _, gui in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if gui.Name:find("OYB") then
            print("Found OYB element:", gui:GetFullName())
            if gui:IsA("TextButton") or gui:IsA("ImageButton") then
                forceClickButton(gui)
            else
                gui.Visible = true
            end
        end
    end
end

-- Run hunt immediately
huntAndOpenOYB()

-- Auto-hunt every 4 seconds
spawn(function()
    while wait(4) do
        huntAndOpenOYB()
    end
end)

-- Hotkeys
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        huntAndOpenOYB()
        print("🔄 Manual OYB hunt triggered")
    end
end)

print("🚀 OYB Panel script active!")
print("Press INSERT to retry. The blue button should get clicked automatically.")

