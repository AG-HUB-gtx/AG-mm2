-- Grok OYB Panel Opener for Coin-Simulator-XI
-- GitHub Raw Compatible - Force opens the blue OYB Panel button

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

print("🔥 Grok OYB Panel Opener Loaded")

local function forceClickButton(button)
    if not button then return end
    button.Visible = true
    button.Active = true
    button.AutoButtonColor = true
    
    pcall(function()
        for _, conn in pairs(button:GetConnections("MouseButton1Click") or {}) do
            conn:Fire()
        end
        if button.Activate then button:Activate() end
        print("✅ Clicked OYB Panel:", button:GetFullName())
    end)
end

local function huntAndOpenOYB()
    print("🔍 Hunting OYB Panel...")
    
    for _, container in ipairs({LocalPlayer.PlayerGui, game:GetService("CoreGui")}) do
        local panel = container:FindFirstChild("OYB Panel", true) 
                     or container:FindFirstChild("OYBPanel", true)
                     or container:FindFirstChild("OYB_Panel", true)
        
        if panel then
            if panel:IsA("TextButton") or panel:IsA("ImageButton") then
                forceClickButton(panel)
            else
                panel.Visible = true
                for _, child in ipairs(panel:GetDescendants()) do
                    if child:IsA("GuiObject") then child.Visible = true end
                end
                print("✅ Forced visible:", panel:GetFullName())
            end
            return true
        end
    end
    
    -- Broader OYB search
    for _, gui in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if gui.Name:find("OYB") or gui.Name:lower():find("oyb") then
            print("Found OYB element:", gui:GetFullName())
            if gui:IsA("TextButton") or gui:IsA("ImageButton") then
                forceClickButton(gui)
            else
                gui.Visible = true
            end
        end
    end
end

-- Initial hunt
huntAndOpenOYB()

-- Auto hunt loop
spawn(function()
    while wait(3) do
        huntAndOpenOYB()
    end
end)

-- Hotkey (INSERT)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        huntAndOpenOYB()
    end
end)

print("🚀 OYB Panel script running. Press INSERT to retry.")

