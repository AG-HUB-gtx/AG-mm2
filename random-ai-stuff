-- Grok Coin Simulator X Auto Farm v3 - Fixed Collection + Rebirth + Zones

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

print("🔥 Grok Auto Farm v3 - Improved Coins + Rebirth + Zones")

local collecting = true
local autoRebirth = true

-- === AUTO COLLECT COINS (more robust) ===
RunService.Heartbeat:Connect(function()
    if not collecting then return end
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _, obj in ipairs(workspace:GetDescendants()) do
        local nameLower = obj.Name:lower()
        if (obj:IsA("BasePart") or obj:IsA("MeshPart")) and 
           (nameLower:find("coin") or nameLower:find("cash") or nameLower:find("money") or nameLower:find("$") or nameLower:find("gem")) then
            
            local dist = (root.Position - obj.Position).Magnitude
            if dist < 150 then
                pcall(function()
                    obj.CFrame = root.CFrame
                end)
            end
        end
    end
end)

-- === SMART AUTO REBIRTH ===
spawn(function()
    while autoRebirth and wait(6) do
        pcall(function()
            -- Search for rebirth button in PlayerGui
            for _, gui in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
                local n = gui.Name:lower()
                if (n:find("rebirth") or n:find("reborn")) and gui:IsA("TextButton") and gui.Visible then
                    gui:Activate()
                    print("✅ Rebirth triggered!")
                    wait(4)
                    break
                end
            end
        end)
    end
end)

-- === AUTO ZONE / MAP PROGRESS ===
spawn(function()
    while wait(3) do
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            -- Strong forward push + slight upward for obstacles
            root.CFrame = root.CFrame * CFrame.new(0, 0, -120)  -- Move forward aggressively
            print("Pushing to next zone...")
        end
    end
end)

-- === CONTROL GUI ===
local sg = Instance.new("ScreenGui")
sg.ResetOnSpawn = false
sg.Parent = LocalPlayer.PlayerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 300, 0, 180)
frame.Position = UDim2.new(0, 30, 0.25, 0)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
frame.Parent = sg

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,40)
title.Text = "Grok Auto Farm v3"
title.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
title.TextScaled = true
title.Parent = frame

local function createToggle(txt, posY, enabled)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = UDim2.new(0.05, 0, 0, posY)
    btn.BackgroundColor3 = enabled and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(180, 0, 0)
    btn.Text = txt .. ": " .. (enabled and "ON" or "OFF")
    btn.TextScaled = true
    btn.Parent = frame
    return btn
end

local collectBtn = createToggle("Auto Collect", 50, true)
collectBtn.MouseButton1Click:Connect(function()
    collecting = not collecting
    collectBtn.Text = "Auto Collect: " .. (collecting and "ON" or "OFF")
    collectBtn.BackgroundColor3 = collecting and Color3.fromRGB(0,180,0) or Color3.fromRGB(180,0,0)
end)

local rebirthBtn = createToggle("Auto Rebirth", 100, true)
rebirthBtn.MouseButton1Click:Connect(function()
    autoRebirth = not autoRebirth
    rebirthBtn.Text = "Auto Rebirth: " .. (autoRebirth and "ON" or "OFF")
    rebirthBtn.BackgroundColor3 = autoRebirth and Color3.fromRGB(0,180,0) or Color3.fromRGB(180,0,0)
end)

print("✅ v3 Loaded! Coins should now pull strongly.")
print("Use the GUI toggles. Rebirth only when button shows.")
print("If still issues, tell me console messages or coin names you see.")
