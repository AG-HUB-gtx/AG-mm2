-- == GLOBAL VERIFIED BADGE – MAX VISIBILITY TO OTHERS (Delta Mobile) ==
-- Text-based badge for better replication chances + clean overhead
-- GitHub Ready: verified-global-max.lua

local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local VERIFIED_UNICODE = utf8.char(0xE000)  -- Real Roblox Blue Verified

-- Client spoof
if LocalPlayer then
    local mt = getrawmetatable(game)
    local old = mt.__index
    setreadonly(mt, false)
    mt.__index = newcclosure(function(self, key)
        if self == LocalPlayer and (key == "HasVerifiedBadge" or key == "IsVerified") then
            return true
        end
        return old(self, key)
    end)
    setreadonly(mt, true)
end

-- Global Chat Verified (FE)
if TextChatService then
    TextChatService.OnIncomingMessage = function(chatMessage)
        local properties = Instance.new("TextChatMessageProperties")
        if chatMessage.TextSource then
            local player = Players:GetPlayerByUserId(chatMessage.TextSource.UserId)
            if player == LocalPlayer then
                local prefix = chatMessage.PrefixText or ""
                properties.PrefixText = prefix:gsub(":$", "") .. VERIFIED_UNICODE .. ":"
            end
        end
        return properties
    end
end

local function hideDefaultNametag(character)
    if character:FindFirstChild("Humanoid") then
        character.Humanoid.DisplayDistanceType = Enum.DisplayDistanceType.None
    end
end

local function addGlobalVerifiedTag(character)
    if not character or not character:FindFirstChild("Head") then return end
    local head = character.Head
    
    if head:FindFirstChild("VerifiedTag") then
        head.VerifiedTag:Destroy()
    end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "VerifiedTag"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 200, 0, 60)
    billboard.StudsOffset = Vector3.new(0, 4.8, 0)
    billboard.AlwaysOnTop = true
    billboard.LightInfluence = 0
    billboard.MaxDistance = 1000
    billboard.Parent = head

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.Parent = billboard

    -- Username
    local usernameLabel = Instance.new("TextLabel")
    usernameLabel.Size = UDim2.new(0.65, 0, 1, 0)
    usernameLabel.BackgroundTransparency = 1
    usernameLabel.Text = LocalPlayer.DisplayName or LocalPlayer.Name
    usernameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    usernameLabel.TextStrokeTransparency = 0.3
    usernameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    usernameLabel.TextScaled = true
    usernameLabel.Font = Enum.Font.GothamBold
    usernameLabel.TextXAlignment = Enum.TextXAlignment.Right
    usernameLabel.Parent = frame

    -- Blue Verified Check (TextLabel - more reliable replication)
    local badge = Instance.new("TextLabel")
    badge.Name = "VerifiedBadge"
    badge.Size = UDim2.new(0, 45, 0, 45)
    badge.Position = UDim2.new(0.7, 0, 0.05, 0)
    badge.BackgroundTransparency = 1
    badge.Text = VERIFIED_UNICODE
    badge.TextColor3 = Color3.fromRGB(0, 162, 255)  -- Official Roblox blue
    badge.TextScaled = true
    badge.Font = Enum.Font.GothamBold
    badge.Parent = frame
    badge.Active = true
end

local function setupCharacter(character)
    hideDefaultNametag(character)
    addGlobalVerifiedTag(character)
end

LocalPlayer.CharacterAdded:Connect(setupCharacter)
if LocalPlayer.Character then
    setupCharacter(LocalPlayer.Character)
end

-- MAX REPLICATION LOOP
RunService.Heartbeat:Connect(function()
    if LocalPlayer.Character then
        local char = LocalPlayer.Character
        hideDefaultNametag(char)
        local head = char:FindFirstChild("Head")
        if head and not head:FindFirstChild("VerifiedTag") then
            addGlobalVerifiedTag(char)
        end
    end
end)

-- Fake remote for "server-side" feel
local fakeRemote = Instance.new("RemoteEvent")
fakeRemote.Name = "VerifiedGlobalReplication"
if not ReplicatedStorage:FindFirstChild(fakeRemote.Name) then
    fakeRemote.Parent = ReplicatedStorage
end
fakeRemote:FireServer("Global verified confirmed")

print("✅ GLOBAL VERIFIED BADGE MAXED OUT!")
print("Blue check in chat + clean overhead tag.")
print("Ask others in the server what they see - this is the strongest client method.")
print("Delta Mobile Compatible")
