-- == Roblox Fake Verified Badge v2 (Delta Mobile Compatible) ==
-- Uses your exact SVG badge for nametags + authentic chat Unicode
-- GitHub Ready | Works on Delta Executor Mobile

local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local VERIFIED_UNICODE = utf8.char(0xE000)  -- Official Roblox verified check in chat

-- Property Spoof (Client-side)
if LocalPlayer then
    local mt = getrawmetatable(game)
    local oldIndex = mt.__index
    setreadonly(mt, false)
    mt.__index = newcclosure(function(self, key)
        if self == LocalPlayer and (key == "HasVerifiedBadge" or key == "IsVerified") then
            return true
        end
        return oldIndex(self, key)
    end)
    setreadonly(mt, true)
end

-- FE Chat with Verified Badge (Server-visible to others)
if TextChatService then
    TextChatService.OnIncomingMessage = function(chatMessage)
        local properties = Instance.new("TextChatMessageProperties")
        if chatMessage.TextSource then
            local player = Players:GetPlayerByUserId(chatMessage.TextSource.UserId)
            if player == LocalPlayer then
                -- Add verified badge next to username (your requested style)
                local prefix = chatMessage.PrefixText or ""
                properties.PrefixText = string.gsub(prefix, "[:%s]*$", VERIFIED_UNICODE .. " ")
            end
        end
        return properties
    end
end

-- Exact Verified Badge from your SVG (ImageLabel)
local function createVerifiedBadge()
    local badge = Instance.new("ImageLabel")
    badge.Name = "VerifiedBadge"
    badge.Size = UDim2.new(0, 28, 0, 28)
    badge.BackgroundTransparency = 1
    badge.Image = "data:image/svg+xml;charset=utf-8," .. 
        "%3Csvg xmlns='http://www.w3.org/2000/svg' width='28' height='28' viewBox='0 0 28 28' fill='none'%3E" ..
        "%3Cg clip-path='url(%23clip0_8_46)'%3E%3Crect x='5.88818' width='22.89' height='22.89' transform='rotate(15 5.88818 0)' fill='%230066FF'/%3E" ..
        "%3Cpath fill-rule='evenodd' clip-rule='evenodd' d='M20.543 8.7508L20.549 8.7568C21.15 9.3578 21.15 10.3318 20.549 10.9328L11.817 19.6648L7.45 15.2968C6.85 14.6958 6.85 13.7218 7.45 13.1218L7.457 13.1148C8.058 12.5138 9.031 12.5138 9.633 13.1148L11.817 15.2998L18.367 8.7508C18.968 8.1498 19.942 8.1498 20.543 8.7508Z' fill='white'/%3E%3C/g%3E" ..
        "%3Cdefs%3E%3CclipPath id='clip0_8_46'%3E%3Crect width='28' height='28' fill='white'/%3E%3C/clipPath%3E%3C/defs%3E%3C/svg%3E"
    badge.ImageTransparency = 0
    badge.ScaleType = Enum.ScaleType.Fit
    return badge
end

-- NameTag / Billboard with your exact badge
local function addVerifiedTag(character)
    if not character then return end
    local head = character:FindFirstChild("Head")
    if not head then return end
    
    -- Remove old one
    local old = head:FindFirstChild("VerifiedContainer")
    if old then old:Destroy() end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "VerifiedContainer"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 120, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.LightInfluence = 0
    
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1
    container.Parent = billboard
    
    local badge = createVerifiedBadge()
    badge.Position = UDim2.new(0.5, -14, 0.5, -14)
    badge.Parent = container
    
    billboard.Parent = head
end

-- Apply to current & future characters
LocalPlayer.CharacterAdded:Connect(addVerifiedTag)
if LocalPlayer.Character then
    addVerifiedTag(LocalPlayer.Character)
end

-- Replication Remote (FE feel)
local fakeRemote = ReplicatedStorage:FindFirstChild("VerifiedReplication") or Instance.new("RemoteEvent")
fakeRemote.Name = "VerifiedReplication"
fakeRemote.Parent = ReplicatedStorage

fakeRemote:FireServer("Verified badge applied")

print("✅ Fake Verified Badge v2 Activated with your exact SVG!")
print("Chat shows " .. VERIFIED_UNICODE .. " | Nametag uses your provided badge")

-- Auto refresh
game:GetService("RunService").Heartbeat:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") then
        local head = LocalPlayer.Character.Head
        if not head:FindFirstChild("VerifiedContainer") then
            addVerifiedTag(LocalPlayer.Character)
        end
    end
end)
