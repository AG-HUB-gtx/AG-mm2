local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local VERIFIED_UNICODE = utf8.char(0xE000)  -- Real Roblox blue verified check

-- Client-side spoof
if LocalPlayer then
    local mt = getrawmetatable(game)
    local oldIndex = mt.__index
    setreadonly(mt, false)
    mt.__index = newcclosure(function(self, key)
        if self == LocalPlayer and (key == "HasVerifiedBadge" or key == "IsVerified") then
            return true
        end
        return oldIndex(self, key)
    end)
    setreadonly(mt, true)
end

-- FE Chat with REAL BLUE Verified
if TextChatService then
    TextChatService.OnIncomingMessage = function(chatMessage)
        local properties = Instance.new("TextChatMessageProperties")
        if chatMessage.TextSource then
            local player = Players:GetPlayerByUserId(chatMessage.TextSource.UserId)
            if player == LocalPlayer then
                local prefix = chatMessage.PrefixText or ""
                properties.PrefixText = prefix:gsub(":$", "") .. VERIFIED_UNICODE .. ":"
            end
        end
        return properties
    end
end

-- Reliable Verified Badge Decal
local VERIFIED_BADGE_ID = "rbxassetid://6023426923"  -- Solid blue verified badge

local function hideDefaultNametag(character)
    if character and character:FindFirstChild("Humanoid") then
        character.Humanoid.DisplayDistanceType = Enum.DisplayDistanceType.None
    end
end

local function addVerifiedTag(character)
    if not character or not character:FindFirstChild("Head") then return end
    local head = character.Head
    
    -- Remove old custom tag
    if head:FindFirstChild("VerifiedTag") then
        head.VerifiedTag:Destroy()
    end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "VerifiedTag"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 190, 0, 60)
    billboard.StudsOffset = Vector3.new(0, 4.5, 0)
    billboard.AlwaysOnTop = true
    billboard.LightInfluence = 0
    billboard.MaxDistance = 1000
    billboard.Parent = head

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.Parent = billboard

    -- Username Label (clean)
    local usernameLabel = Instance.new("TextLabel")
    usernameLabel.Size = UDim2.new(0.7, 0, 1, 0)
    usernameLabel.BackgroundTransparency = 1
    usernameLabel.Text = LocalPlayer.DisplayName or LocalPlayer.Name
    usernameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    usernameLabel.TextStrokeTransparency = 0.3
    usernameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    usernameLabel.TextScaled = true
    usernameLabel.Font = Enum.Font.GothamBold
    usernameLabel.TextXAlignment = Enum.TextXAlignment.Right
    usernameLabel.Parent = frame

    -- Verified Badge (real-looking)
    local badge = Instance.new("ImageLabel")
    badge.Name = "VerifiedBadge"
    badge.Size = UDim2.new(0, 42, 0, 42)
    badge.Position = UDim2.new(0.72, 0, 0.08, 0)
    badge.BackgroundTransparency = 1
    badge.Image = VERIFIED_BADGE_ID
    badge.ImageTransparency = 0
    badge.Parent = frame
    badge.Active = true
end

-- Apply everything on character spawn
local function onCharacterAdded(character)
    hideDefaultNametag(character)
    addVerifiedTag(character)
end

LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
if LocalPlayer.Character then
    onCharacterAdded(LocalPlayer.Character)
end

-- Persistence loop
RunService.Heartbeat:Connect(function()
    if LocalPlayer.Character then
        local head = LocalPlayer.Character:FindFirstChild("Head")
        if head and not head:FindFirstChild("VerifiedTag") then
            addVerifiedTag(LocalPlayer.Character)
        end
        hideDefaultNametag(LocalPlayer.Character)
    end
end)

-- Fake server replication
local fakeRemote = Instance.new("RemoteEvent")
fakeRemote.Name = "VerifiedReplication"
if not ReplicatedStorage:FindFirstChild(fakeRemote.Name) then
    fakeRemote.Parent = ReplicatedStorage
end
fakeRemote:FireServer("Server confirmed verified user")

print("✅ CLEAN REAL BLUE VERIFIED BADGE ACTIVE!")
print("Default nametag hidden. Custom badge should be clean.")
print("Ask friends if they see the blue check next to your name!")
print("Delta Mobile Compatible")
