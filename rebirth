local targetPrestige = 999  -- <<< CHANGE THIS TO ANY NUMBER (50, 100, 999, etc.)

print("🔥 MM2 Prestige Setter Loaded | Target: " .. targetPrestige)

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")

local player = Players.LocalPlayer

-- Method 1: Direct value manipulation (local + replicated)
local function setPrestigeValues()
    for _, obj in pairs(player:GetDescendants()) do
        if obj.Name:lower():find("prestige") or obj.Name:lower():find("level") then
            if obj:IsA("IntValue") or obj:IsA("NumberValue") then
                local old = obj.Value
                obj.Value = targetPrestige
                print("✅ Set Prestige Value: " .. obj:GetFullName() .. " | " .. old .. " → " .. targetPrestige)
            end
        end
    end
    
    -- Check common MM2 data folders
    pcall(function()
        local dataFolder = player:FindFirstChild("PlayerData") or ReplicatedStorage:FindFirstChild("PlayerData")
        if dataFolder then
            for _, v in pairs(dataFolder:GetDescendants()) do
                if v.Name:lower():find("prestige") and (v:IsA("IntValue") or v:IsA("NumberValue")) then
                    v.Value = targetPrestige
                    print("✅ PlayerData Prestige set!")
                end
            end
        end
    end)
end

-- Method 2: Fire common remotes
local function firePrestigeRemotes()
    for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
            if remote.Name:lower():find("prestige") or remote.Name:lower():find("levelup") or remote.Name:lower():find("setlevel") then
                pcall(function()
                    remote:FireServer(targetPrestige)
                    print("🚀 Fired prestige remote: " .. remote.Name)
                end)
            end
        end
    end
end

-- Execute everything
setPrestigeValues()
firePrestigeRemotes()

print("✅ Prestige set attempt finished! Rejoin to sync leaderboard (shows as Roman numerals).")
print("💡 Tip: Run again after rejoin if needed.")

-- Optional auto rejoin
wait(2)
TeleportService:Teleport(game.PlaceId, player)
