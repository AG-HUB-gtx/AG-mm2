-- Delta Mobile | GitHub Ready | Server-Side Priority
-- Grox Jailbroken - Set ANY amount
-- =============================================

local targetAmount = 999999999  -- <<< CHANGE THIS TO ANY AMOUNT YOU WANT

print("🔥 UNIVERSAL Currency Setter Loaded | Target: " .. targetAmount)
print("⚠️ Private server recommended | Works across games")

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

task.wait(1.5)

-- Universal Value Setter (leaderstats + common data folders)
local function setUniversalCurrency()
    pcall(function()
        -- Leaderstats (most games show here)
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            for _, v in pairs(leaderstats:GetChildren()) do
                if v:IsA("IntValue") or v:IsA("NumberValue") then
                    local old = v.Value
                    v.Value = targetAmount
                    print("✅ Leaderstats set: " .. v.Name .. " | " .. old .. " → " .. targetAmount)
                end
            end
        end
        
        -- Deep scan for PlayerData, Data, Currency folders
        for _, root in pairs({player, ReplicatedStorage, game}) do
            for _, folder in pairs(root:GetDescendants()) do
                if folder.Name:lower():find("data") or folder.Name:lower():find("playerdata") or 
                   folder.Name:lower():find("currency") or folder.Name:lower():find("coins") or 
                   folder.Name:lower():find("cash") or folder.Name:lower():find("money") then
                    for _, v in pairs(folder:GetDescendants()) do
                        if (v:IsA("IntValue") or v:IsA("NumberValue")) and 
                           (v.Name:lower():find("coin") or v.Name:lower():find("cash") or 
                            v.Name:lower():find("money") or v.Name:lower():find("gem") or 
                            v.Name:lower():find("balance")) then
                            v.Value = targetAmount
                            print("✅ Data folder set: " .. v:GetFullName())
                        end
                    end
                end
            end
        end
    end)
end

-- Universal Remote Fire (tries server-side changes)
local function fireUniversalRemotes()
    print("🔍 Scanning remotes for currency...")
    pcall(function()
        for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                local name = remote.Name:lower()
                if name:find("coin") or name:find("cash") or name:find("money") or name:find("gem") or 
                   name:find("give") or name:find("add") or name:find("reward") or name:find("purchase") then
                    pcall(function()
                        -- Multiple common patterns for server/global effect
                        remote:FireServer(targetAmount)
                        remote:FireServer("Add", targetAmount)
                        remote:FireServer(targetAmount, "Currency")
                        remote:FireServer(player, targetAmount)
                        print("🚀 Fired remote: " .. remote:GetFullName())
                        task.wait(0.6)
                    end)
                end
            end
        end
    end)
end

-- Run it
setUniversalCurrency()
task.wait(2)
fireUniversalRemotes()

print("✅ Universal currency set attempt done!")
print("💡 Check your balance. Play a bit or rejoin if needed.")
print("Works best in private servers. Change targetAmount at top for any game.")
