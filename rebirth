setButton.Text = "SET CURRENCY"
setButton.TextColor3 = Color3.fromRGB(255, 255, 255)
setButton.TextScaled = true
setButton.Parent = frame

-- Make draggable for mobile
local dragging = false
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
    end
end)
frame.InputEnded:Connect(function()
    dragging = false
end)
game:GetService("RunService").RenderStepped:Connect(function()
    if dragging then
        local mousePos = game:GetService("UserInputService"):GetMouseLocation()
        frame.Position = UDim2.new(0, mousePos.X - 150, 0, mousePos.Y - 100)
    end
end)

-- Main Set Function (Universal across games)
local function setCurrency(targetAmount)
    print("🔥 Setting currency to: " .. targetAmount)
    
    -- Leaderstats (most visible)
    pcall(function()
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            for _, v in pairs(leaderstats:GetChildren()) do
                if v:IsA("IntValue") or v:IsA("NumberValue") then
                    v.Value = targetAmount
                    print("✅ Leaderstats set: " .. v.Name)
                end
            end
        end
    end)
    
    -- Deep data scan
    pcall(function()
        for _, root in pairs({player, ReplicatedStorage, game}) do
            for _, folder in pairs(root:GetDescendants()) do
                if folder.Name:lower():find("data") or folder.Name:lower():find("playerdata") or 
                   folder.Name:lower():find("currency") or folder.Name:lower():find("coins") or 
                   folder.Name:lower():find("cash") or folder.Name:lower():find("money") or 
                   folder.Name:lower():find("gem") then
                    for _, v in pairs(folder:GetDescendants()) do
                        if (v:IsA("IntValue") or v:IsA("NumberValue")) and 
                           (v.Name:lower():find("coin") or v.Name:lower():find("cash") or 
                            v.Name:lower():find("money") or v.Name:lower():find("gem") or 
                            v.Name:lower():find("balance")) then
                            v.Value = targetAmount
                            print("✅ Data set: " .. v:GetFullName())
                        end
                    end
                end
            end
        end
    end)
    
    -- Universal remotes (server-side push)
    pcall(function()
        for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                local name = remote.Name:lower()
                if name:find("coin") or name:find("cash") or name:find("money") or name:find("gem") or 
                   name:find("give") or name:find("add") or name:find("reward") or name:find("purchase") then
                    pcall(function()
                        remote:FireServer(targetAmount)
                        remote:FireServer("Add", targetAmount)
                        remote:FireServer(targetAmount, "Currency")
                        remote:FireServer(player, targetAmount)
                        print("🚀 Fired: " .. remote:GetFullName())
                    end)
                end
            end
        end
    end)
    
    print("✅ Universal set complete! Check balance in-game.")
end

-- Button click
setButton.MouseButton1Click:Connect(function()
    local amount = tonumber(amountBox.Text)
    if amount then
        setCurrency(amount)
    else
        print("❌ Invalid number!")
    end
end)

print("✅ GUI ready! Enter amount and click SET.")
