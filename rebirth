local targetCoins = 99999999  -- <<< CHANGE THIS TO ANY AMOUNT (millions+)

print("🔥 MM2 Server-Side Coins Setter Loaded | Target: " .. targetCoins)
print("⚠️ Private server recommended - Anti-cheat watch")

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

task.wait(1.5)

-- Server-side focused: Find & fire coin-related remotes first
local function fireServerCoinRemotes()
    print("🔍 Scanning for server coin remotes...")
    pcall(function()
        for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                local name = remote.Name:lower()
                if name:find("coin") or name:find("cash") or name:find("give") or name:find("addmoney") or name:find("reward") then
                    pcall(function()
                        remote:FireServer(targetCoins, "CoinPack")  -- Common args
                        print("🚀 Fired server remote: " .. remote:GetFullName())
                        task.wait(0.8)  -- Stealth delay
                    end)
                end
            end
        end
    end)
end

-- Deep data manipulation (server-synced values)
local function setServerCoinValues()
    pcall(function()
        -- Leaderstats (server visible)
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            for _, v in pairs(leaderstats:GetChildren()) do
                if v.Name:lower():find("coin") or v.Name:lower():find("cash") and (v:IsA("IntValue") or v:IsA("NumberValue")) then
                    v.Value = targetCoins
                    print("✅ Leaderstats (server) set: " .. v.Name)
                end
            end
        end
        
        -- PlayerData / other server folders
        for _, folder in pairs({player, ReplicatedStorage}) do
            local data = folder:FindFirstChild("PlayerData") or folder:FindFirstChild("Data") or folder:FindFirstChild("Coins")
            if data then
                for _, v in pairs(data:GetDescendants()) do
                    if (v.Name:lower():find("coin") or v.Name:lower():find("cash")) and (v:IsA("IntValue") or v:IsA("NumberValue")) then
                        v.Value = targetCoins
                        print("✅ Server Data folder set!")
                    end
                end
            end
        end
    end)
end

-- Run server priority
fireServerCoinRemotes()
task.wait(2)
setServerCoinValues()

print("✅ Server-side coins attempt complete!")
print("💡 Stay in game 1-2 rounds. Check balance / leaderboard.")
print("If not sticking, use Private Server + run again.")
